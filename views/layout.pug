doctype html
html.h-100
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no")
        block css
            link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet")
            link(href="/css/index.css" rel="stylesheet")
        title
            block title
            = " | Jelly G.allery"
        block head
    body.d-flex.flex-column.h-100
        nav.navbar.sticky-top
            .container-fluid
                a(href="/")
                    .navbar-brand.mb-0.h1 Jelly G.allery
        main.flex-grow-1
            div.w-100.h-100
                block content
        footer.footer.mt-auto.py-2.text-body-secondary
            .container.d-flex.justify-content-around.text-center
                span.nav-link The Jelly G.allery
                a.nav-link(href="https://github.com/oceanuwu/jellygallery2") GitHub
                a.nav-link(href="/admin") Admin
        block js
            script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js")
            script(src="/js/index.js")