doctype html
html.h-100
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no")
        block css
            link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet")
            link(href="/css/index.css" rel="stylesheet")
        title
            block title
            = " | Jelly G.allery"
        block head
    body
        nav.navbar.sticky-top.py-1
            .container-fluid.mx-3
                .navbar-brand.mb-0.h1 Jelly G.allery
        main.main
            .main-inside
                .centre-area
                    .content
                        block content
        footer.footer.mt-auto.py-2
            .container.d-flex.justify-content-around.text-center
                div: span.nav-link #[b The Jelly G.allery] by ocean
                div: a.nav-link(href="https://github.com/oceanuwu/jellygallery2") GitHub
                div: a.nav-link(href="/admin") Admin
        block js
            script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js")
            script(src="/js/index.js")