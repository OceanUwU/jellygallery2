doctype html
html.h-100
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no")
        link(rel="icon" type="image/x-icon" href="/img/icon.png")
        block css
            link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet")
            link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet")
            link(href="/css/index.css" rel="stylesheet")
        title
            block title
            = " | Jelly G.allery"
        block head
    body
        nav.navbar.navbar-expand-lg.sticky-top.py-1
            .container-fluid.mx-3
                a.navbar-brand.mb-0.h1(href="/") Jelly G.allery
                button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation")
                    span.navbar-toggler-icon
                .collapse.navbar-collapse#navbarSupportedContent
                    ul.navbar-nav.me-auto.mb-2.mb-lg-0
                        li.nav-item
                            a.nav-link(href="/entries" class=url.startsWith("/entries") ? "active" : "") Entries
                        li.nav-item
                            a.nav-link(href="/arcs" class=url.startsWith("/arcs") ? "active" : "") Arcs
                        //-li.nav-item
                        //-    a.nav-link(href="/characters" class=url.startsWith("/characters") ? "active" : "") Characters
                    .form
                        .input-group
                            input.form-control#searchBox(type="search" placeholder="Search" aria-label="Search" aria-describedby="searchButton" maxlength=25)
                            button.btn.btn-outline-light#searchButton(type="submit"): i.bi.bi-search
        main.main
            .main-inside
                .centre-area
                    .content
                        block content
        footer.footer.mt-auto.py-2
            .container.d-flex.justify-content-around.text-center
                div: a.nav-link(href="/rss") RSS
                div: a.nav-link(href="https://github.com/oceanuwu/jellygallery2") GitHub
                div: a.nav-link(href="/admin") Admin
        block js
            script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js")
            script(type="module" src="/js/index.js")